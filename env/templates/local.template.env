# ============================================================
# TEMPLATE ENVIRONMENT CONFIGURATION
# ============================================================
# This is a sanitized example environment configuration file
# for local ASP.NET Core development.
#
# Copy this file to:
#   env/local.env
#
# Then replace placeholder values with your local settings.
#
# IMPORTANT:
# - Do NOT commit real secrets
# - Do NOT commit production credentials
# - This configuration is intended for development only
# ============================================================

# ----------------------------------------
# Environment
# ----------------------------------------
ASPNETCORE_ENVIRONMENT=Development
Runtime__Platform=Local

# ----------------------------------------
# Token validation mode (API)
# ----------------------------------------
TokenSettings__Mode=Reference

# ----------------------------------------
# Identity Provider (IDP)
# ----------------------------------------
# Public origin / issuer of the IDP
IDP_PUBLIC_ORIGIN=https://localhost:5001

# IdentityServer signing certificate
IdentityServer__SigningCertPath=certs/imagegallery-signing.pfx
IdentityServer__SigningCertPassword=<YOUR_CERT_PASSWORD>

# ----------------------------------------
# Authentication__Authority
#   Used by:
#   - MVC Client → OIDC login, token acquisition
#   - API → token validation (JWT or introspection)
#
# Authentication__ClientId / ClientSecret
#   Used by:
#   - MVC Client only (OIDC client credentials)
#
# NOTE:
# Authority is shared between client and API in this project,
# but they represent different responsibilities:
# - Client → OAuth/OIDC client behavior (requesting tokens)
# - API → Resource server behavior (validating tokens)
# ----------------------------------------
Authentication__Authority=https://localhost:5001
# OIDC security behavior
Authentication__RequireHttpsMetadata=true

Authentication__ClientId=imagegalleryclient
Authentication__ClientSecret=YOUR_CLIENT_SECRET

# API (used for token introspection against IDP)
Authentication__ApiClientId=imagegalleryapi
Authentication__ApiClientSecret=YOUR_API_CLIENT_SECRET

# ----------------------------------------
# Client URLs (used by IDP to build OIDC RedirectUris and PostLogoutRedirectUris)
# MUST match the actual URL where the client application is running
# ----------------------------------------
CLIENTURLS__BASEURL=https://localhost:7184

# ----------------------------------------
# Client → API
# ----------------------------------------
ImageGalleryAPIRoot=https://localhost:7075

# ----------------------------------------
# Public URLs (browser-facing)
# ----------------------------------------
# Used by the MVC client to render image URLs that the browser can access
ImageGalleryPublicRoot=https://localhost:7075

# ----------------------------------------
# Database
# ----------------------------------------
ConnectionStrings__ImageGalleryDBConnectionString=Server=localhost,1433;Database=ImageGalleryDb;User Id=sa;Password=YOUR_DB_PASSWORD;Encrypt=False;TrustServerCertificate=True;MultipleActiveResultSets=true

# ----------------------------------------
# AWS S3 Image Storage
# ----------------------------------------
Storage__Provider=Local
AWS__Region=us-east-2
AWS__S3ImageBucket=imagegallery-dev-images