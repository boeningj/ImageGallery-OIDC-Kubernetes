# ============================================================
# TEMPLATE ENVIRONMENT CONFIGURATION
# ============================================================
# This is a sanitized example environment configuration file
# for local Docker development.
#
# Copy this file to:
#   env/docker.env
#
# Then replace placeholder values with your local settings.
#
# IMPORTANT:
# - Do NOT commit real secrets
# - Do NOT commit production credentials
# - This configuration is intended for development only
# ============================================================

# ============================================================
# PROJECT OVERVIEW
# ============================================================
# This configuration demonstrates a production-style setup where:
# - nginx handles HTTPS/TLS termination
# - IdentityServer runs behind a reverse proxy with a path base (/idp)
# - Client and API run in containers and communicate over an internal Docker network

# ============================================================
# ARCHITECTURE OVERVIEW
# ============================================================
# There are TWO network contexts in this setup:
#
# 1) Browser (public):
#    https://localhost:5000  → nginx → containers
#
# 2) Docker network (internal):
#    http://imagegallery-*:port
#
# Rules:
# - Anything the browser sees MUST use https://localhost:5000
# - Container-to-container calls MUST use http://imagegallery-*
# - "localhost" inside a container refers to the container itself (NOT the host)
#
# Mixing these will break authentication.
# ============================================================

# ========================================
# ENVIRONMENT
# ========================================
ASPNETCORE_ENVIRONMENT=Docker
TRUST_FORWARD_HEADERS=true

# ========================================
# TOKEN VALIDATION MODE (API)
# ========================================
# Reference = Use opaque tokens (requires introspection)
#   - Tokens are validated by calling the IDP (/connect/introspect)
#   - Supports immediate revocation
#   - Adds network overhead
#
# Jwt = Use self-contained tokens
#   - Tokens are validated locally using signing keys (no network call)
#   - Better performance (stateless)
#   - Revocation is not immediate (depends on token lifetime or additional mechanisms)
# NOTE:
# This project uses Reference tokens by default to demonstrate introspection-based validation in a microservices environment.
TokenSettings__Mode=Reference

# ========================================
# IDENTITY PROVIDER (PUBLIC URL)
# ========================================
# This MUST match how the BROWSER accesses the IDP.  It is used for:
# - token issuer (iss claim)
# - OIDC redirects
# - discovery document endpoints returned to clients
# Since nginx terminates HTTPS, this must be HTTPS.
IDP_PUBLIC_ORIGIN=https://localhost:5000/idp

# ========================================
# AUTHENTICATION (CLIENT APP)
# ========================================
# IMPORTANT: TWO different URLs are used depending on context:
#
# 1. Authority (PUBLIC - used for browser redirects)
#    → must be accessible from the browser
# 2. MetadataAddress (INTERNAL - used by container)
#    → must be reachable from inside Docker network
#
# This avoids:
# - containers calling https://localhost (wrong)
# - SSL issues inside Docker
Authentication__Authority=https://localhost:5000/idp

# MetadataAddress uses host.docker.internal intentionally.
# This routes from the container → host → IDP container via published port.
# It avoids HTTPS/self-signed cert issues inside Docker.
#
# NOTE:
# This is a DEV convenience. A pure Docker approach would use:
#   http://imagegallery-idp:5001/idp/.well-known/openid-configuration
# but that requires careful alignment of path base (/idp) and issuer settings.
#
# Do NOT change unless you fully understand nginx forwarding and IDP issuer behavior.
Authentication__MetadataAddress=http://host.docker.internal:5001/idp/.well-known/openid-configuration

# Disable HTTPS requirement for metadata (internal HTTP is intentional)
Authentication__RequireHttpsMetadata=false

# ========================================
# INTERNAL IDENTITY (API → IDP)
# ========================================
# Used by the API for token validation:
# - Reference tokens → calls /connect/introspect
# - JWT tokens       → fetches discovery document + signing keys
#
# This MUST use the internal Docker network address (imagegallery-idp),
# NOT https://localhost, because:
# - Containers cannot reliably call localhost on the host
# - HTTPS is terminated by nginx externally
# Communication here is container-to-container over HTTP.
# This is safe because it never leaves the Docker network.
#
# The /idp path base is required because the IDP uses app.UsePathBase("/idp").
InternalIdentity__Authority=http://imagegallery-idp:5001/idp

# Disable HTTPS requirement for metadata since internal calls use HTTP
InternalIdentity__RequireHttpsMetadata=false

# ============================================================
# DEVELOPMENT ONLY - Disable SSL Certificate Validation
# ============================================================
# Required because nginx uses a self-signed cert for https://localhost:5000.
# When containers make HTTPS back-channel calls (e.g., to the IDP discovery endpoint),
# this certificate is not trusted, causing requests to fail.
#
# This setting disables certificate validation for those internal HttpClient calls.
# DO NOT use in production.
OIDC__DISABLECERTVALIDATION=true

# OIDC client credentials
Authentication__ClientId=imagegalleryclient
Authentication__ClientSecret=YOUR_CLIENT_SECRET

# API client (used for token introspection against IDP)
Authentication__ApiClientId=imagegalleryapi
Authentication__ApiClientSecret=YOUR_API_CLIENT_SECRET

# ========================================
# CLIENT URLS (USED BY IDP)
# ========================================
# This is used by IdentityServer to build:
# - RedirectUris
# - PostLogoutRedirectUris
# MUST match the browser URL (nginx endpoint)
CLIENTURLS__BASEURL=https://localhost:5000

# ========================================
# CLIENT → API COMMUNICATION
# ========================================
# Internal Docker network address (NOT browser)
ImageGalleryAPIRoot=http://imagegallery-api:5075

# ----------------------------------------
# Public URLs (browser-facing)
# ----------------------------------------
ImageGalleryPublicRoot=https://localhost:5000

# ========================================
# DATABASE (API)
# ========================================
# SQLite file is baked into the container image.
# IMPORTANT:
# - /app must be writable by 'app' user
# - Required for SQLite WAL/journal files
ConnectionStrings__ImageGalleryDBConnectionString=Data Source=ImageGallery.db

# ========================================
# HTTPS Development Certificate
# ========================================
ASPNETCORE_Kestrel__Certificates__Default__Password=YOUR_CERT_PASSWORD